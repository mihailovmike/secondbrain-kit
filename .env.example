# === Required ===
GEMINI_API_KEY=
SECONDBRAIN_API_KEY=change-me-to-random-string

# === Vault ===
# Docker: /app/vault | Local: /path/to/your/vault
VAULT_PATH=/app/vault
INBOX_DIR_NAME=_inbox

# === LightRAG ===
LIGHTRAG_WORKING_DIR=/app/vault/.lightrag
LIGHTRAG_LLM_MODEL=gemini-2.5-pro
LIGHTRAG_EMBEDDING_MODEL=gemini-embedding-001
LIGHTRAG_EMBEDDING_DIMENSIONS=3072
LIGHTRAG_CHUNK_SIZE=1200
# NanoVectorDBStorage (local dev) or QdrantVectorDBStorage (production)
LIGHTRAG_VECTOR_STORAGE=QdrantVectorDBStorage

# === Qdrant (production) ===
QDRANT_URL=http://secondbrain-qdrant:6333

# === Optional: Telegram notifications ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DM_CHAT_ID=

# === Optional: LLM model override ===
LLM_MODEL=gemini-2.5-pro
MERGE_THRESHOLD=0.85

# === Optional: WebUI auth ===
WEBUI_USERNAME=admin
WEBUI_PASSWORD=change-me
WEBUI_JWT_SECRET=change-me-to-random-string

# === Optional: proxy (for geo-restricted Gemini API) ===
# HTTPS_PROXY=
