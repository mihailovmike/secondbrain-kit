# === Required ===
GEMINI_API_KEY=
SECONDBRAIN_API_KEY=

# === Vault ===
# Docker: /app/vault | Local: /Users/you/coding/SecondBrain
VAULT_PATH=/app/vault
INBOX_DIR_NAME=_inbox
# Pipe-separated list of root-level owner/hub files that should be indexed
# despite living at vault root (owner profile, orientation anchors).
# Example: VAULT_OWNER_FILES="Mikhail Mikhailov.md|owner.md"
VAULT_OWNER_FILES=

# When true, periodic vault sync deletes orphan docs from the graph after
# min_orphan_age_sec (default 120). When false, orphans are reported only.
AUTO_SYNC_DELETE=true

# Linker auto-links to hub: if any note mentions the anchor hub title or an
# alias, [[ANCHOR_HUB_TITLE]] is added to its suggested wiki-links.
# Aliases pipe-separated. Leave empty to disable.
ANCHOR_HUB_TITLE=
ANCHOR_HUB_ALIASES=

# === LightRAG ===
LIGHTRAG_WORKING_DIR=/app/vault/.lightrag
LIGHTRAG_LLM_MODEL=gemini-2.5-pro
LIGHTRAG_EMBEDDING_MODEL=gemini-embedding-001
LIGHTRAG_EMBEDDING_DIMENSIONS=3072
LIGHTRAG_CHUNK_SIZE=1200
# NanoVectorDBStorage (local) or QdrantVectorDBStorage (production)
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

# === Qdrant (production only) ===
QDRANT_URL=http://secondbrain-qdrant:6333

# === Layer 2 archives (vector-only storage, sessions/transcripts/dumps) ===
# Separate Qdrant collection with embeddings only (no entity extraction).
# Used for notes with frontmatter `layer: 2` or `processing: vector`.
QDRANT_ARCHIVE_COLLECTION=secondbrain_archives
ARCHIVE_EMBEDDING_DIM=3072

# === Graph deduplication (LightRAG WebUI) ===
# Internal URL used by daemon to call WebUI API for entity merges
LIGHTRAG_WEBUI_URL=http://secondbrain-webui:9621
# SECONDBRAIN_API_KEY is reused as X-API-KEY for WebUI auth

# === Optional ===
LLM_MODEL=gemini-2.5-pro
CLASSIFY_MODEL=gemini-2.5-flash
MERGE_THRESHOLD=0.85
HTTPS_PROXY=

# === Approval workflow ===
# approve = Telegram inline buttons, notify = auto-place + notify, auto = silent
APPROVAL_MODE=approve

# === Auto-approve (disabled by default — enable only after dry-run review) ===
# When enabled, /approval/auto-process acts on queue entries older than TTL:
#   - Sessions/compact: auto-deleted.
#   - Knowledge notes with confidence >= AUTO_APPROVE_CONFIDENCE AND resolved
#     folder AND no near-duplicate (>= AUTO_APPROVE_DEDUP_THRESHOLD) are
#     auto-moved to their proposed folder with Telegram undo notification.
# When disabled, the endpoint runs as dry-run and returns a would-do report.
AUTO_APPROVE_ENABLED=false
AUTO_APPROVE_TTL_HOURS=24
AUTO_APPROVE_CONFIDENCE=0.9
AUTO_APPROVE_DEDUP_THRESHOLD=0.80
AUTO_DELETE_SESSIONS=true

# === Telegram notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_DM_CHAT_ID=
TELEGRAM_INBOX_CHAT_ID=
TELEGRAM_INBOX_THREAD_ID=
# Public GitHub blob URL for "Читать" links in approval messages
VAULT_GITHUB_URL=https://github.com/mihailovmike/SecondBrain/blob/main
